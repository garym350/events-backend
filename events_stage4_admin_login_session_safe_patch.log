    24	function toIso(v: any): string | null {
    25	  if (!v) return null;
    26	  if (typeof v?.toDate === "function") return v.toDate().toISOString(); // Firestore Timestamp
    27	  if (v instanceof Date) return v.toISOString();
    28	  if (typeof v?.seconds === "number") {
    29	    const ms = v.seconds * 1000 + Math.floor((v.nanoseconds ?? 0) / 1e6);
    30	    return new Date(ms).toISOString();
    31	  }
    32	  if (typeof v === "string") {
    33	    const s = v.trim();
    34	    let d = new Date(s);
    35	    if (!isNaN(d.getTime())) return d.toISOString();
