    69	export async function listEvents(): Promise<Event[]> {
    70	  const r = await fetch(`${BASE}/events`, { cache: "no-store" });
    71	  if (!r.ok) throw new Error("Failed to load events");
    72	  const data = await r.json();
    73	  return Array.isArray(data) ? (data as Event[]) : (data.events as Event[]);
    74	}
    75	
    76	export async function getEvent(id: string): Promise<Event> {
    77	  const r = await fetch(`${BASE}/events/${id}`, { cache: "no-store" });
    78	  if (!r.ok) throw new Error("Not found");
    79	  return (await r.json()) as Event;
    80	}
    81	
    82	export async function createEvent(
    83	  payload: CreateEventInput,
    84	  adminPass: string
    85	): Promise<Event> {
    86	  if (!adminPass || !adminPass.trim()) {
    87	    throw new Error("Missing admin passcode (frontend)");
    88	  }
    89	
    90	  const r = await fetch(`${BASE}/events`, {
    91	    method: "POST",
    92	    headers: {
    93	      "Content-Type": "application/json",
    94	      "x-admin-passcode": adminPass.trim(),
    95	    },
    96	    body: JSON.stringify(payload),
    97	  });
    98	
    99	  if (!r.ok) {
   100	    let message = "Create event failed";
   101	    try {
   102	      const e = await r.json();
   103	      if (e?.error)
   104	        message =
   105	          typeof e.error === "string" ? e.error : JSON.stringify(e.error);
   106	    } catch {}
   107	    throw new Error(message);
   108	  }
   109	  return (await r.json()) as Event;
   110	}
   111	
   112	export async function updateEvent(
   113	  id: string,
   114	  payload: UpdateEventInput,
   115	  adminPass: string
   116	): Promise<Event> {
   117	  if (!adminPass || !adminPass.trim()) {
   118	    throw new Error("Missing admin passcode (frontend)");
   119	  }
   120	
   121	  const r = await fetch(`${BASE}/events/${id}`, {
   122	    method: "PUT",
   123	    headers: {
   124	      "Content-Type": "application/json",
   125	      "x-admin-passcode": adminPass.trim(),
   126	    },
   127	    body: JSON.stringify(payload),
   128	  });
   129	
   130	  if (!r.ok) {
   131	    let message = "Update event failed";
   132	    try {
   133	      const e = await r.json();
   134	      if (e?.error) message = typeof e.error === "string" ? e.error : JSON.stringify(e.error);
   135	    } catch {}
   136	    throw new Error(message);
   137	  }
   138	  return (await r.json()) as Event;
   139	}
