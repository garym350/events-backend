    29	
    30	const rawOrigins = String(process.env.ALLOW_ORIGINS ?? process.env.ALLOW_ORIGIN ?? "");
    31	const parsedEnvOrigins = rawOrigins
    32	  .split(",")
    33	  .map((s) => s.trim())
    34	  .filter((s) => s.length > 0)
    35	  .map((s) => s.replace(/\/$/, "")); // drop trailing slash after trimming
    36	
    37	const defaultDevOrigins = [
    38	  "http://localhost:3000",
    39	  "http://127.0.0.1:3000",
    40	  "http://localhost:3001",
    41	  "http://127.0.0.1:3001",
    42	];
    43	
    44	const allowedOrigins = Array.from(new Set([...defaultDevOrigins, ...parsedEnvOrigins]));
    45	const corsWarned = new Set<string>(); // avoid repeating the same warning
    46	
    47	const corsOptions: CorsOptions = {
    48	  // Return false (don’t throw) so tests/clients see a clean CORS denial
    49	  origin(origin, callback) {
    50	    if (!origin) return callback(null, true); // server-to-server / curl / tests
    51	
    52	    const normalized = origin.replace(/\/$/, "");
    53	    const ok =
    54	      allowedOrigins.includes(normalized) ||
    55	      /^http:\/\/(localhost|127\.0\.0\.1):\d+$/.test(normalized) ||
    56	      /^http:\/\/192\.168\.\d+\.\d+(?::\d+)?$/.test(normalized) ||
    57	      /^https:\/\/[a-z0-9-]+\.netlify\.app$/.test(normalized);
    58	
    59	    if (ok) return callback(null, true);
    60	
    61	    if (!corsWarned.has(origin)) {
    62	      corsWarned.add(origin);
    63	      console.warn("[CORS] blocked origin:", origin);
    64	    }
    65	    return callback(null, false);
    66	  },
    67	  methods: ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    68	  allowedHeaders: ["Content-Type", "Authorization", "x-admin-passcode"],
    69	  optionsSuccessStatus: 200,
    70	};
    71	
    72	app.use(cors(corsOptions));
    73	// Express 5 + path-to-regexp v6: use a regexp instead of "*"
    74	app.options(/.*/, cors(corsOptions));
