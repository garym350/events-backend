     1	import { describe, expect, it } from "vitest";
     2	import { EventSchema } from "../src/lib/schemas.js";
     3	
     4	function validEvent(overrides: Record<string, unknown> = {}) {
     5	  const start = new Date(Date.now() + 24 * 60 * 60 * 1000);
     6	  const end = new Date(start.getTime() + 2 * 60 * 60 * 1000);
     7	
     8	  return {
     9	    title: "Future Film Night",
    10	    description: "A valid future event description.",
    11	    location: "Main Screen",
    12	    start: start.toISOString(),
    13	    end: end.toISOString(),
    14	    priceType: "free",
    15	    ...overrides,
    16	  };
    17	}
    18	
    19	function issueMessages(result: ReturnType<typeof EventSchema.safeParse>) {
    20	  return result.success ? [] : result.error.issues.map((issue) => issue.message);
    21	}
    22	
    23	describe("EventSchema backend date validation", () => {
    24	  it("accepts a valid future event inside the supported date range", () => {
    25	    const result = EventSchema.safeParse(validEvent());
    26	    expect(result.success).toBe(true);
    27	  });
    28	
    29	  it("rejects an event whose end time is not after its start time", () => {
    30	    const start = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();
    31	    const result = EventSchema.safeParse(validEvent({ start, end: start }));
    32	
    33	    expect(result.success).toBe(false);
    34	    expect(issueMessages(result)).toContain("The event end time must be after the start time.");
    35	  });
    36	
    37	  it("rejects an event that starts in the past", () => {
    38	    const start = new Date(Date.now() - 60 * 60 * 1000);
    39	    const end = new Date(Date.now() + 60 * 60 * 1000);
    40	    const result = EventSchema.safeParse(validEvent({ start: start.toISOString(), end: end.toISOString() }));
    41	
    42	    expect(result.success).toBe(false);
    43	    expect(issueMessages(result)).toContain("Events cannot be created in the past. Please choose a future start date.");
    44	  });
    45	
    46	  it("rejects event dates more than five years ahead", () => {
    47	    const tooFar = new Date(Date.now());
    48	    tooFar.setUTCFullYear(tooFar.getUTCFullYear() + 6);
    49	    const tooFarEnd = new Date(tooFar.getTime() + 2 * 60 * 60 * 1000);
    50	    const result = EventSchema.safeParse(validEvent({ start: tooFar.toISOString(), end: tooFarEnd.toISOString() }));
    51	
    52	    expect(result.success).toBe(false);
    53	    expect(issueMessages(result)).toContain("Event dates must be within the current year and the next 5 years.");
    54	  });
    55	});

