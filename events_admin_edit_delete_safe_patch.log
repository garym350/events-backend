    27	function toLocalDateTimeValue(value: string | null | undefined) {
    28	  if (!value) return "";
    29	  const date = new Date(value);
    30	  if (Number.isNaN(date.getTime())) return "";
    31	  const offsetMs = date.getTimezoneOffset() * 60 * 1000;
    32	  return new Date(date.getTime() - offsetMs).toISOString().slice(0, 16);
    33	}
